# ==============================================================================
# ENVIRONMENT-BASED CONFIGURATION
# ==============================================================================
#
# This project uses SEPARATE Supabase projects for DEV and PRODUCTION:
# - Development: Use this .env file with DEV credentials
# - Production: Configure Vercel/hosting environment variables
#
# The same codebase connects to different databases based on environment.
# No code conditionals needed - just configure the right credentials!
#
# ==============================================================================

# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard
#
# IMPORTANT: Use your DEVELOPMENT project here. Production uses Vercel env vars.
VITE_SUPABASE_PROJECT_ID="your-dev-project-id"
VITE_SUPABASE_URL="https://your-dev-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-dev-anon-key"

# Supabase Admin (DO NOT expose these in frontend code)
# Only needed for CLI operations, migrations, and server-side functions
SUPABASE_SERVICE_ROLE_KEY="your-dev-service-role-key"
SUPABASE_ACCESS_TOKEN="your-access-token"

# Stripe Configuration
# IMPORTANT: Match Stripe keys to your Supabase environment!
# - DEV Supabase = sk_test_* keys (this file)
# - PROD Supabase = sk_live_* keys (Vercel env vars)
STRIPE_SECRET_KEY="sk_test_your-stripe-test-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ==============================================================================
# PRODUCTION SETUP (Vercel/Hosting)
# ==============================================================================
#
# Configure these environment variables in your hosting platform:
#
# VITE_SUPABASE_PROJECT_ID = "your-prod-project-id"
# VITE_SUPABASE_URL = "https://your-prod-project-id.supabase.co"
# VITE_SUPABASE_PUBLISHABLE_KEY = "your-prod-anon-key"
# STRIPE_SECRET_KEY = "sk_live_..."
# STRIPE_WEBHOOK_SECRET = "whsec_..."
#
# ==============================================================================
